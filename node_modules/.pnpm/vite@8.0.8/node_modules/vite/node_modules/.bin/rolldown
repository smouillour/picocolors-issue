#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../rolldown@1.0.0-rc.15/node_modules/rolldown/bin/cli.mjs" "$@"
else
  exec node  "$basedir/../../../../../rolldown@1.0.0-rc.15/node_modules/rolldown/bin/cli.mjs" "$@"
fi
